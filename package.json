{
  "name": "jblib",
  "version": "0.0.1",
  "description": "libraries, utilities, and configs i use to make stuff",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "fmt": "prettier --check --cache .",
    "fmt:fix": "prettier --write --cache .",
    "sherif": "sherif",
    "sherif:fix": "sherif -f",
    "ci": "pnpm run fmt && pnpm run lint && pnpm run test",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install --no-frozen-lockfile && pnpm fmt:fix",
    "changeset:publish": "changeset publish"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "jiti": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "sherif": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "private": true
}
