{
  "name": "@jblib/eslint-react",
  "version": "0.0.1",
  "description": "base eslint react config",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "@eslint/js": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "eslint": "catalog:",
    "@types/eslint": "catalog:",
    "prettier": "catalog:",
    "@jblib/eslint": "workspace:*",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "keywords": [
    "eslint",
    "react",
    "config"
  ],
  "author": {
    "name": "Joseph Beck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joseph-beck/jblib.git",
    "directory": "packages/eslint-react"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  }
}
