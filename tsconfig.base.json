{
  "compilerOptions": {
    "target": "ES2022",
    "skipLibCheck": true,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "outDir": "dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
