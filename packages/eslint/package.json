{
  "name": "@jblib/eslint",
  "version": "0.0.3",
  "description": "base eslint config",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "typescript-eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "globals": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@eslint/js": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "eslint": "catalog:",
    "@types/eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "keywords": [
    "eslint",
    "config"
  ],
  "author": {
    "name": "Joseph Beck"
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joseph-beck/jblib.git",
    "directory": "packages/eslint"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  }
}
